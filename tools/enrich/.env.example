# Copy this file to .env and fill in your API key.
# .env is gitignored — never commits.

# Anthropic (Haiku 4.5 — default + only supported provider for enrichment).
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# ENRICH_MODEL=claude-haiku-4-5-20251001
# ENRICH_BATCH_SIZE=50               # items per LLM call (default 50)
# ENRICH_LIMIT=0                     # set >0 to cap total items processed (testing / cost trials)
# ENRICH_DRY_RUN=0                   # set to 1 to skip LLM calls (diff + cost estimate only)
